<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connect to Device"
        android:textColor="#F0F4FF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvDialogDeviceName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#00D4AA"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvDialogSSID"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#6B7280"
        android:textSize="13sp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tvDialogStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFB347"
        android:textSize="13sp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnDialogCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="Cancel"
            android:textColor="#6B7280"
            android:backgroundTint="#1F2937"/>

        <Button
            android:id="@+id/btnDialogConnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect"
            android:textColor="#0A0F1E"
            android:backgroundTint="#00D4AA"/>

    </LinearLayout>

</LinearLayout>